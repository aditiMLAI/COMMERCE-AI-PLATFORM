                                                                                                                                                                                                            
  # OS                                                                                                                                                                                                                                   
                                                                                                                                                                                                               
  .DS_Store                                                 
                                                                                                                                                                                                                                         
                                  
  # Python / FastAPI backend

  apps/api/__pycache__/
  apps/api/**/__pycache__/
  **/__pycache__/
  **/*.pyc
  .env
  .venv/
  venv/

  # pytest / coverage
  .pytest_cache/
  .coverage
  htmlcov/


  # Node / React frontend

  apps/web/node_modules/
  apps/web/build/
  apps/web/dist/
  apps/web/.env
  apps/web/.vite/

  # logs
  npm-debug.log*
  yarn-debug.log*
  yarn-error.log*


  # IDEs
  
  .vscode/
  .idea/